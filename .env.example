# Required API keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional
GEMINI_API_KEY=
GITHUB_TOKEN=ghp_...

# Project path on host (the repo you want overstory to work on)
PROJECT_PATH=/path/to/your/repo

# Claude config path (agent definitions, commands, settings)
CLAUDE_CONFIG=~/.claude

# Logging level
OVERSTORY_LOG_LEVEL=info
